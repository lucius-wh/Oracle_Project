<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.oracleproject.mapper.StudentMapper">

    <!-- 根据ID查询学生详情 -->
    <select id="findById"
            parameterType="java.lang.Integer"
            resultType="com.oracleproject.model.Student">

        select
            sid,
            sname,
            gender,
            classname as className,
            is_delete as isDelete
        from shanxi_ancient_student
        where sid = #{sid}
          and is_delete = 0

    </select>

    <!-- 逻辑删除学生 -->
    <update id="deleteStudent"
            parameterType="java.lang.Integer">

        update shanxi_ancient_student
        set is_delete = 1
        where sid = #{sid}

    </update>

    <!-- 删除该学生所有参观记录 -->
    <update id="deleteStudentRel"
            parameterType="java.lang.Integer">

        update student_build_rel
        set is_delete = 1
        where sid = #{sid}

    </update>

</mapper>